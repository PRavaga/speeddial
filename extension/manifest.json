{
  "manifest_version": 3,
  "name": "Speed Dial",
  "version": "2.2.2",
  "description": "Tab command center — organize, manage, and backup your browser tabs",
  "key": "",
  "permissions": ["tabs", "tabGroups", "storage", "alarms", "favicon", "unlimitedStorage", "identity"],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
